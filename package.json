{
  "name": "@openclaw/libterminal",
  "version": "0.3.2",
  "description": "Shared TypeScript terminal protocol, streaming, browser, Node, and Worker primitives",
  "keywords": [
    "ghostty",
    "openclaw",
    "pty",
    "terminal",
    "typescript",
    "websocket"
  ],
  "homepage": "https://github.com/openclaw/libterminal#readme",
  "bugs": {
    "url": "https://github.com/openclaw/libterminal/issues"
  },
  "license": "MIT",
  "author": "OpenClaw Team <dev@openclaw.ai>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openclaw/libterminal.git"
  },
  "files": [
    "dist",
    "protocol",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js"
    },
    "./stream": {
      "types": "./dist/stream.d.ts",
      "import": "./dist/stream.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js"
    },
    "./worker-assets": {
      "types": "./dist/worker-assets.d.ts",
      "import": "./dist/worker-assets.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    },
    "./protocol/terminal-v2.json": "./protocol/terminal-v2.json",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "pnpm run generate:worker-assets && tsdown src/index.ts src/protocol.ts src/stream.ts src/browser.ts src/node.ts src/worker.ts src/worker-assets.ts src/testing.ts --format esm --dts --clean --target es2023 --no-fixedExtension --deps.never-bundle ghostty-web --deps.never-bundle node-pty",
    "check": "pnpm run format:check && pnpm run build && pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run pack:check",
    "check:release": "pnpm run check && pnpm run test:browser",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "generate:worker-assets": "node scripts/generate-worker-ghostty-assets.mjs",
    "lint": "pnpm run generate:worker-assets && oxlint --type-aware --deny-warnings src test",
    "pack:check": "node scripts/check-pack.mjs",
    "prepack": "pnpm run build",
    "test": "pnpm run generate:worker-assets && vitest run",
    "test:browser": "pnpm run build && playwright test",
    "typecheck": "pnpm run generate:worker-assets && tsc --noEmit && tsc -p tsconfig.portable.json --noEmit"
  },
  "dependencies": {
    "ghostty-web": "0.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@typescript/native": "npm:typescript@^7.0.2",
    "node-pty": "^1.1.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "tsdown": "^0.22.7",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "node-pty": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "node-pty": {
      "optional": true
    }
  },
  "engines": {
    "node": "^22.18.0 || >=24.11.0"
  },
  "packageManager": "pnpm@10.33.2"
}
